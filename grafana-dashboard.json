{
  "title": "FundExporter",
  "tags": ["fund", "finance"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "title": "總市值 vs 總成本",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum(fund_value)", "legendFormat": "總市值"},
        {"expr": "sum(fund_cost)", "legendFormat": "總成本"}
      ]
    },
    {
      "id": 2,
      "title": "各基金市值走勢",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [
        {"expr": "fund_value", "legendFormat": "{{fund_name}}"}
      ]
    },
    {
      "id": 3,
      "title": "持倉明細與漲跌幅",
      "type": "table",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [
        {"expr": "fund_cost", "legendFormat": "成本", "format": "table"},
        {"expr": "fund_units", "legendFormat": "單位數", "format": "table"},
        {"expr": "fund_nav", "legendFormat": "淨值", "format": "table"},
        {"expr": "fund_value", "legendFormat": "市值", "format": "table"},
        {"expr": "fund_cost_value_ratio", "legendFormat": "比例", "format": "table"},
        {"expr": "(fund_value - fund_value offset 1d) / fund_value offset 1d * 100", "legendFormat": "日漲跌%", "format": "table"},
        {"expr": "(fund_value - fund_value offset 7d) / fund_value offset 7d * 100", "legendFormat": "週漲跌%", "format": "table"},
        {"expr": "(fund_value - fund_value offset 30d) / fund_value offset 30d * 100", "legendFormat": "月漲跌%", "format": "table"}
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "groupBy", "options": {
          "fields": {
            "fund_name": {"aggregations": [], "operation": "groupby"},
            "成本": {"aggregations": ["last"], "operation": "aggregate"},
            "單位數": {"aggregations": ["last"], "operation": "aggregate"},
            "淨值": {"aggregations": ["last"], "operation": "aggregate"},
            "市值": {"aggregations": ["last"], "operation": "aggregate"},
            "比例": {"aggregations": ["last"], "operation": "aggregate"},
            "日漲跌%": {"aggregations": ["last"], "operation": "aggregate"},
            "週漲跌%": {"aggregations": ["last"], "operation": "aggregate"},
            "月漲跌%": {"aggregations": ["last"], "operation": "aggregate"}
          }
        }}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "center"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "日漲跌%"}, "properties": [
            {"id": "custom.cellOptions", "value": {"type": "color-text", "mode": "basic"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0, "color": "red"}]}},
            {"id": "unit", "value": "percent"}
          ]},
          {"matcher": {"id": "byName", "options": "週漲跌%"}, "properties": [
            {"id": "custom.cellOptions", "value": {"type": "color-text", "mode": "basic"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0, "color": "red"}]}},
            {"id": "unit", "value": "percent"}
          ]},
          {"matcher": {"id": "byName", "options": "月漲跌%"}, "properties": [
            {"id": "custom.cellOptions", "value": {"type": "color-text", "mode": "basic"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0, "color": "red"}]}},
            {"id": "unit", "value": "percent"}
          ]},
          {"matcher": {"id": "byName", "options": "比例"}, "properties": [
            {"id": "unit", "value": "percent"}
          ]}
        ]
      }
    }
  ]
}
